<% layout("layouts/boilerplate") %>
<%
    const filterIcons = {
        trending: "fa-solid fa-fire",
        rooms: "fa-solid fa-bed",
        cities: "fa-solid fa-mountain-city",
        mountains: "fa-solid fa-mountain",
        castles: "fa-brands fa-fort-awesome",
        pools: "fa-solid fa-person-swimming",
        camping: "fa-solid fa-campground",
        farms: "fa-solid fa-tractor",
        arctic: "fa-regular fa-snowflake",
    };
%>

<div id="filters" class="filters-bar">
    <% Object.entries(categoryLabels).forEach(([category, label]) => { %>
        <a
            class="filter <%= currentCategory === category ? 'active' : '' %>"
            href="/listings?<%= new URLSearchParams({ ...(currentSearch ? { q: currentSearch } : {}), category }).toString() %>"
        >
            <div><i class="<%= filterIcons[category] %>"></i></div>
            <p><%= label %></p>
        </a>
    <% }) %>
    <a class="clear-filter-link" href="/listings<%= currentSearch ? `?${new URLSearchParams({ q: currentSearch }).toString()}` : '' %>">Clear filters</a>
    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>

<div class="results-header">
    <div>
        <h1 class="page-title">Stay where the story feels right</h1>
        <p class="page-subtitle">
            <% if (currentSearch && currentCategory) { %>
                Showing places for "<%= currentSearch %>" in <%= categoryLabels[currentCategory] %>.
            <% } else if (currentSearch) { %>
                Showing places for "<%= currentSearch %>".
            <% } else if (currentCategory) { %>
                Showing <%= categoryLabels[currentCategory] %> stays.
            <% } else { %>
                Browse hand-picked places for city breaks, mountain escapes, and everything between.
            <% } %>
        </p>
    </div>
</div>

<div class="row row-cols-xl-3 row-cols-md-2 row-cols-1 g-4 mt-1">
    <% if (allListings.length === 0) { %>
        <div class="col-12">
            <div class="empty-state">
                <h3>No places matched your search.</h3>
                <p>Try another city, country, or category.</p>
                <a href="/listings" class="btn btn-dark">See all places</a>
            </div>
        </div>
    <% } %>

    <% for(let listing of allListings) { %>
        <div class="col">
            <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
                <div class="card listing-card">
                    <img
                        src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/600x400?text=No+Image' %>"
                        class="card-img-top listing-image"
                        alt="listing_image"
                    >

                    <div class="card-body">
                        <div class="listing-meta">
                            <span class="listing-badge"><%= categoryLabels[listing.primaryCategory] || "Trending" %></span>
                            <span class="listing-place"><%= listing.location %>, <%= listing.country %></span>
                        </div>
                        <p class="card-text listing-copy">
                            <b><%= listing.title %></b> <br>
                            <span class="listing-price">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</span>
                            <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <div class="mt-2">
                <a href="/listings/<%= listing._id %>/book" class="btn btn-outline-dark w-100">Book now</a>
            </div>
        </div>
    <% } %>
</div>

<script>
  const taxSwitch = document.getElementById("flexSwitchCheckDefault");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      const taxInfo = document.querySelectorAll(".tax-info");
      taxInfo.forEach(info => {
        info.style.display = taxSwitch.checked ? "inline" : "none";
      });
    });
  }
</script>
